# Neon Postgres connection string. Same value works locally and on Vercel.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Anthropic API key, used for query expansion and relevance scoring.
ANTHROPIC_API_KEY=sk-ant-...

# Shared secret for the daily cron route. Vercel sends this as `Authorization: Bearer $CRON_SECRET`.
CRON_SECRET=generate-a-long-random-string
